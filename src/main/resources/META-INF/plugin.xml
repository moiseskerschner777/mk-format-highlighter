<idea-plugin>
    <id>com.moiseskerschner.mkformat</id>
    <name>mk-format Highlighter</name>
    <vendor>Moises Kerschner</vendor>
    <description>Depth-colored syntax highlighting for mk-format (.mk) outline files, matching the mk-editor artifact's palette out of the box.</description>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <fileType
            name="mk-format"
            implementationClass="com.moiseskerschner.mkformat.MkFileType"
            fieldName="INSTANCE"
            language="mk-format"
            extensions="mk"/>
        <lang.syntaxHighlighterFactory
            language="mk-format"
            implementationClass="com.moiseskerschner.mkformat.MkSyntaxHighlighterFactory"/>
        <colorSettingsPage implementation="com.moiseskerschner.mkformat.MkColorSettingsPage"/>
        <lang.psiStructureViewFactory
            language="mk-format"
            implementationClass="com.moiseskerschner.mkformat.MkStructureViewFactory"/>
        <lang.parserDefinition
            language="mk-format"
            implementationClass="com.moiseskerschner.mkformat.MkParserDefinition"/>
        <lang.foldingBuilder
            language="mk-format"
            implementationClass="com.moiseskerschner.mkformat.MkFoldingBuilder"/>
        <codeInsight.lineMarkerProvider
            language="mk-format"
            implementationClass="com.moiseskerschner.mkformat.comments.MkCommentGutterProvider"/>
    </extensions>

    <actions>
        <action id="MkComments.LogComments" class="com.moiseskerschner.mkformat.comments.LogCommentsAction"
                text="Log mk Comments" description="Log all stacked mk comments">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
        <action id="MkComments.AddComment" class="com.moiseskerschner.mkformat.comments.AddCommentInlineAction"
                text="Add Comment" description="Add a comment for the selected text">
            <keyboard-shortcut keymap="$default" first-keystroke="ctrl alt shift A"/>
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
